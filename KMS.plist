<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>items</key>
    <array>
        <dict>
            <key>assets</key>
            <array>
                <!-- 1. IPA安装包地址 -->
                <dict>
                    <key>kind</key>
                    <string>software-package</string>
                    <key>url</key>
                    <string>https://github.com/inspur-tms/kms_cbe/releases/download/1.0.93/__UNI__3B8DFDC_0112151353.ipa</string>
                </dict>
                <!-- 2. 安装时展示的App图标 -->
                <dict>
                    <key>kind</key>
                    <string>display-image</string>
                    <key>needs-shine</key>
                    <false/>
                    <key>url</key>
                    <string>https://inspur-tms.github.io/kms_cbe/logo.png</string>
                </dict>
            </array>
            <!-- 3. App元数据信息，必须和打包证书配置保持一致 -->
            <key>metadata</key>
            <dict>
                <!-- 应用唯一包名（Bundle ID）：打包时配置的ID必须是 com.inspur.obd.cbe.kms，否则安装失败 -->
                <key>bundle-identifier</key>
                <string>ccom.inspur.obd.cbe.kms</string>
                <!-- 版本号 -->
                <key>bundle-version</key>
                <string>100</string>
                <key>kind</key>
                <string>software</string>
                <!-- 手机桌面显示的App名称 -->
                <key>title</key>
                <string>KMS</string>
            </dict>
        </dict>
    </array>
</dict>
</plist>
